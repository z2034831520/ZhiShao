# RDK -> Windows VLM brain address
ZHISHAO_VLM_SERVER_IP=10.134.157.114
ZHISHAO_VLM_SERVER_PORT=9000

# The Windows service at 10.134.157.114:9000 is windows_brain/vlm_service_cascade.py.
# It calls DashScope / Qwen-VL. RDK does not run the vision-language model.
ZHISHAO_BRAIN_URL_ANALYZE=http://10.134.157.114:9000/analyze
ZHISHAO_BRAIN_URL_ASK=http://10.134.157.114:9000/ask
ZHISHAO_BRAIN_URL_SUMMARIZE=http://10.134.157.114:9000/summarize
ZHISHAO_BRAIN_URL_PRIVACY_CHECK=http://10.134.157.114:9000/privacy_check

# Care location shown in assistant replies and weather context.
# Public IP geolocation is disabled by default because mobile hotspots may report a nearby city.
ZHISHAO_CARE_CITY=马鞍山
ZHISHAO_CARE_LOCATION=中国 安徽 马鞍山
ZHISHAO_USE_IP_GEOLOCATION=false

# Feishu bot
FEISHU_WEBHOOK=your_feishu_webhook_url
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
